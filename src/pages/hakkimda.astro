---
import PageWrapper from "../components/page-wrapper.astro";
import Layout from "../layouts/base-layout.astro";
import LinkButton from "../components/link-button.astro";
import ImagePlaceholder from "../components/image-placeholder.astro";
---

<Layout title="WhitePoplinShirt">
  <PageWrapper active="about" mainId="top" contentClass="flex flex-col gap-0">
    <div class="flex flex-col gap-8 py-8 sm:flex-row sm:items-start sm:py-12">
      <div class="flex flex-col gap-6 sm:flex-[3]">
        <h1
          class="text-brand-secondary border-brand-accent/60 animate-fade-in-up border-l-4 pl-4 font-sans text-3xl leading-tight font-light italic sm:text-5xl"
        >
          Hakkımda
        </h1>

        <p
          class="text-brand-accent/85 animate-fade-in-up animation-delay-150 leading-relaxed font-light"
        >
          Merhaba, ben Esen Bacalan. İletişim alanında lisans eğitimimi
          tamamladıktan sonra uzun yıllar kurumsal şirketlerde uluslararası
          pazarlama yöneticiliği yaptım. Çocukluk hayalim olan moda alanındaki
          eğitimimi ise 2019 yılında İstanbul Moda Akademisi'nde Moda Yönetimi
          programıyla tamamladım.
        </p>

        <!-- Mobile photo: between first and second paragraph -->
        <ImagePlaceholder
          class="animate-fade-in animation-delay-150 sm:hidden"
        />

        <p
          class="text-brand-accent/85 animate-fade-in-up animation-delay-150 leading-relaxed font-light"
        >
          Kurumsal deneyimimle moda bilgisini bir araya getiren bu yolculuk,
          zamanla styling ve gardırop danışmanlığına evrilen bir yaklaşımın
          temelini oluşturdu. 2023 yılında içerik üretmeye başladım;
          WhitePoplinShirt ise 2025'te bu yaklaşımın netleştiği bir platform
          hâline geldi.
        </p>

        <p
          class="text-brand-accent/85 animate-fade-in-up animation-delay-150 leading-relaxed font-light"
        >
          Bugün odağım; trendleri dayatmadan, bilinçli alışverişi merkeze alan,
          kişinin yaşam tarzına ve ihtiyaçlarına uygun stil çözümleri sunmak.
          Sahip olduklarını doğru şekilde kullanarak işlevsel ve sürdürülebilir
          bir gardırop oluşturmana destek oluyorum.
        </p>

        <p
          class="text-brand-accent/85 animate-fade-in-up animation-delay-150 leading-relaxed font-light"
        >
          Eğer stilini netleştirmek ve dolabınla daha güçlü bir ilişki kurmak
          istiyorsan, bu yolculukta sana rehberlik etmek için buradayım.
        </p>

        <div
          class="animate-fade-in-up animation-delay-300 flex flex-wrap items-center gap-3 pt-0.5"
        >
          <LinkButton
            href="mailto:info@whitepoplinshirt.com"
            text="info@whitepoplinshirt.com"
            iconClass="icon-[ri--mail-send-line] text-brand-primary text-2xl"
          />

          <LinkButton
            href={import.meta.env.INSTAGRAM_URL}
            text="Instagram"
            iconClass="icon-[ri--instagram-line] text-brand-primary text-2xl"
          />
        </div>
      </div>

      <!-- Desktop photo: sticky right column -->
      <div
        class="animate-fade-in animation-delay-150 hidden sm:block sm:flex-[2]"
      >
        <div class="sticky top-8">
          <ImagePlaceholder aspect="aspect-[3/4]" />
        </div>
      </div>
    </div>
  </PageWrapper>
</Layout>
