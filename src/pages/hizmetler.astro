---
import PageWrapper from "../components/page-wrapper.astro";
import Layout from "../layouts/base-layout.astro";
import LinkButton from "../components/link-button.astro";
import TipsDialogue from "../components/tips-dialogue.astro";

const services = [
  {
    title: "Online Styling Seansı",
    duration: "1 saat",
    details: [
      "Bu bir saatlik online styling seansında, gardırobunuzu detaylı bir şekilde birlikte analiz ediyoruz. Mevcut parçalarınızı kategorize edip, en verimli şekilde nasıl kullanabileceğinizi değerlendiriyor, stilinize uygun kombinler oluşturuyor ve styling ile ilgili tüm sorularınızı yanıtlıyorum.",
      "Seans sırasında stilinizi güçlendirecek ancak gardırobunuzda eksik olan temel parçaları belirliyorum. Seansın ardından; size özel stil önerileri ve ihtiyaçlarınıza uygun satın alma linklerini içeren kişiselleştirilmiş bir e-posta paylaşıyorum.",
      "Bu hizmet; kişisel stilini netleştirmek, gardırobunu daha işlevsel hâle getirmek ve her gün ne giyeceğine kolayca karar verebilmek isteyen kişiler için ideal bir başlangıç seansıdır.",
    ],
  },
  {
    title: "Mini Online Styling Seansı",
    duration: "30dk",
    details: [
      "Bu hizmet;",
      "- Belirli etkinliklere özel kombin yapmak isteyenler,",
      "- Gardırobundaki bazı parçaları- sevdiği halde- nasıl kombinleyeceğini bilemeyenler",
      "- Bir stil danışmanıyla çalışma deneyimi yaşamak isteyenler ve",
      "- Kişisel stilini oturtmuş ancak farklı kombinler oluşturma konusunda yeni bir bakış açısı arayanlar",
      "için, kısa ancak bilgilendirici bir seanstır.",
    ],
  },
  {
    title: "Online Gardırop Temizliği ve Düzenleme Sistemi",
    duration: "1.5 saat",
    details: [
      "Giyinmek, kombin yapmak ve gardırobunda vakit geçirmek keyifli olmalı; stresli değil. Ancak gardırobumuz kıyafetle dolup taştığında, çoğu zaman neye sahip olduğumuzu unutur; sürekli alışveriş yapmamıza rağmen \u201Cne giyeceğim?\u201D sorusuyla karşı karşıya kalırız. Bu döngü, zamanla stres ve kaygıya dönüşebilir.",
      "WhitePoplinShirt ile gerçekleştirdiğimiz bu 1,5 saatlik online gardırop temizleme ve düzenleme sistemi seansında, tüm gardırobunu birlikte ele alıyor ve yalnızca 5 adımlık etkili bir sistemle onu daha kullanışlı, daha sakin, daha organize ve en önemlisi giyinmenin yeniden keyifli olduğu bir alana dönüştürüyoruz.",
      "Seans sırasında; nasıl kombinleyeceğini bilmediğin ve dolabında uzun süredir atıl kalan parçaları da günlük hayatına tekrar kazandırıyoruz. Seansın ardından gardırobun, içinde vakit geçirmekten keyif alacağın ve rahatça kombin yapabileceğin yeni favori alanın hâline geliyor.",
      "Bu hizmet; kişisel stilini büyük ölçüde oturtmuş ancak kombin yaparken kendini tembel ya da ilhamsız hisseden, gardırobundaki kaosu nasıl düzene sokacağını bilemeyen ve özellikle mevsim geçişlerinde gardırobunu daha etkili bir sistemle yönetmek isteyenler için idealdir.",
    ],
  },
];

const sessionTips = {
  items: [
    "Soracağınız soruları seans öncesi hazırlayınız.",
    "\u201CNasıl kombinlerim?\u201D dediğiniz parçaları seans öncesi hazırlayınız.",
    "Seans sırasında tartıştığımız kombinlerin fotoğraflarını çekmeyi unutmayınız. Böylece o parçalarla farklı looklar için ilham noktanız oluşmuş olur (kombinleri ister yere serip fotoğrafını çekebilir, isterseniz üzerinizde denerken fotoğraflayabilirsiniz).",
    "Seansa Ipad veya Laptop ile katılmanızı tavsiye ederiz. Böylece seans sırasında telefonunuzla fotoğraf çekme olanağınız olacaktır.",
    "Dilerseniz seans sırasında not alabilir veya seansı kaydedebilirsiniz.",
  ],
  note: "SEANS İPTALİ KABUL EDİLMEMEKTEDİR. Ancak, seanstan 24 saat öncesine kadar slotunuzu başka bir tarihe yeniden organize edebilirsiniz.",
};
---

<Layout title="WhitePoplinShirt">
  <PageWrapper active="services" mainId="top">
    <div class="divide-brand-accent/20 divide-y">
      {
        services.map((service, index) => (
          <div
            class="animate-fade-in-up flex flex-col gap-6 py-6 sm:flex-row sm:gap-12 sm:py-12"
            style={`animation-delay: ${index * 150}ms`}
          >
            <div class="flex flex-col sm:w-56 sm:shrink-0">
              <span class="font-sans-headline text-brand-secondary text-7xl leading-none font-bold">
                {String(index + 1).padStart(2, "0")}
              </span>
              <h2 class="text-brand-secondary mt-2 text-xl font-bold tracking-wide uppercase">
                {service.title}
              </h2>
              <p class="text-brand-accent/60 mt-1 text-xs font-light tracking-widest uppercase">
                {service.duration}
              </p>
            </div>

            <div class="flex flex-1 flex-col gap-6">
              <div class="space-y-3">
                {service.details.map((detail) => (
                  <p class="text-brand-accent/85 text-sm leading-relaxed font-light">
                    {detail}
                  </p>
                ))}
              </div>
              <div class="flex flex-wrap gap-3">
                <LinkButton
                  href={import.meta.env.CALENDAR_URL}
                  text="Şimdi Randevu Al"
                />
                <LinkButton
                  href="#session-tips"
                  target="_self"
                  variant="ghost"
                  text="Seans İçin İpuçları"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <TipsDialogue items={sessionTips.items} note={sessionTips.note} />
  </PageWrapper>
</Layout>
