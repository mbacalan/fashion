---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  href: string;
  text: string;
  iconClass?: string;
  variant?: "filled" | "secondary" | "ghost";
}

const {
  href,
  text,
  iconClass,
  target,
  referrerpolicy,
  variant = "secondary",
} = Astro.props;

const variantClasses =
  variant === "filled"
    ? "bg-brand-primary text-brand-secondary"
    : variant === "ghost"
      ? "ring-2 ring-brand-accent/60 text-brand-accent bg-transparent"
      : "bg-brand-secondary text-brand-primary";
---

<a
  href={href}
  target={target ?? "_blank"}
  referrerpolicy={referrerpolicy ?? "same-origin"}
  class={`focus-visible:outline-brand-secondary/60 inline-flex items-center justify-center rounded-sm px-5 py-3 text-base font-semibold tracking-wide transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 sm:px-6 ${variantClasses}`}
>
  {iconClass ? <span class={iconClass + " mr-2"} /> : null}
  {text}
</a>
