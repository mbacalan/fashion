---
interface SiteNavProps {
  active: "home" | "about" | "services";
}

const { active } = Astro.props as SiteNavProps;

const linkClasses = (key: SiteNavProps["active"]) =>
  [
    "relative inline-flex items-center px-1 py-1 border-b-2 transition-opacity",
    active === key
      ? "border-brand-primary font-semibold"
      : "border-transparent opacity-70 hover:opacity-100",
  ].join(" ");
---

<nav class="text-brand-primary text-sm font-medium uppercase">
  <ul class="flex flex-wrap items-center gap-2 sm:justify-end sm:gap-3">
    <li>
      <a href="/" class={linkClasses("home")}>Ana Sayfa</a>
    </li>
    <li>
      <a href="/hakkimda" class={linkClasses("about")}>Hakkımda</a>
    </li>
    <li>
      <a href="/hizmetler" class={linkClasses("services")}>Hizmetler</a>
    </li>
    <li>
      <a href="https://instagram.com" referrerpolicy="origin" target="_blank">
        <span class="icon-[ri--instagram-line] text-brand-primary text-2xl"
        ></span>
      </a>
    </li>
  </ul>
</nav>
