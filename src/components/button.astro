---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  text: string;
  iconClass?: string;
}

const { text, iconClass, ...rest } = Astro.props;
---

<button
  class="bg-brand-primary focus-visible:outline-brand-secondary/60 text-brand-secondary inline-flex w-full rounded-sm px-5 py-3 text-lg font-semibold tracking-wide transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 sm:w-auto sm:px-6"
  {...rest}
>
  {iconClass ? <span class={iconClass + " mr-2"} /> : null}
  {text}
</button>
