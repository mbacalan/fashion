---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  text: string;
  iconClass?: string;
  variant?: "filled" | "outlined" | "ghost";
}

const { text, iconClass, variant = "filled", ...rest } = Astro.props;

const variantClasses =
  variant === "outlined"
    ? "ring-2 ring-brand-primary text-brand-primary bg-transparent"
    : variant === "ghost"
      ? "ring-2 ring-brand-accent/60 text-brand-accent bg-transparent"
      : "bg-brand-primary text-brand-secondary";
---

<button
  class={`focus-visible:outline-brand-secondary/60 inline-flex rounded-sm px-5 py-3 text-base font-semibold tracking-wide transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 sm:px-6 ${variantClasses}`}
  {...rest}
>
  {iconClass ? <span class={iconClass + " mr-2"} /> : null}
  {text}
</button>
