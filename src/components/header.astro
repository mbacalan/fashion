---
import SiteNav from "./site-nav.astro";

interface Props {
  active: "home" | "about" | "services";
}

const { active } = Astro.props as Props;
---

<header
  class="bg-brand-secondary border-brand-primary/20 border-b px-5 py-4 sm:px-8"
>
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex items-center gap-4">
      <a href="/" class="flex flex-col leading-tight">
        <span
          class="font-sans-headline text-brand-primary text-2xl font-bold tracking-widest"
        >
          WhitePoplinShirt
        </span>
      </a>
    </div>
    <div class="w-full sm:flex sm:w-auto sm:justify-end">
      <SiteNav active={active} />
    </div>
  </div>
</header>
